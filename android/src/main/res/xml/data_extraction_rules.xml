<?xml version="1.0" encoding="utf-8"?>
<!-- Backups are disabled in AndroidManifest.xml via android:allowBackup="false".
     These explicit excludes keep local tuning data out of cloud backup/device transfer
     if backup settings change later. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
